# Скопируй в .env и подставь свои значения (файл .env в репозиторий не коммитится).

# Telegram
# TELEGRAM_BOT_TOKEN=
# ADMIN_TELEGRAM_ID=
# MARATHON_GROUP_IDS=

# --- AI: «Живой Мост» — сначала Gemini, при 429/503 после ретраев — Groq (OpenAI-compatible) ---
# Ключ Google AI (Gemini). Можно задать как PRIMARY_API_KEY или как раньше:
# PRIMARY_API_KEY=
# GOOGLE_AI_KEY=
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_FALLBACK=
# GEMINI_API_VERSION=v1beta

# Запасной канал (Groq): ключ и опционально URL/модель
# FALLBACK_API_KEY=
# То же, что FALLBACK_API_KEY (если удобнее старое имя):
# GROQ_API_KEY=
# FALLBACK_BASE_URL=https://api.groq.com/openai/v1
# FALLBACK_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=

# PostgreSQL (опционально; пароль с # & лучше в кавычках)
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_USER=
# POSTGRES_PASSWORD=""
# POSTGRES_DB=
# Либо одной строкой для библиотек, ожидающих URL (спецсимволы в пароле — URL-encode)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Дайджест мечт из БД: автоматически при старте бота (сек задержки). 0 = не слать; сводка по запросу: /s
# Нужны POSTGRES_* выше и: pip install 'psycopg[binary]'
# DREAM_DIGEST_BOOT_DELAY_SEC=0

# Кампания Bloom (тест 26.03): крон МСК, приветствие в группу, учёт личных сообщений в bloom_private_contacts
# pip install apscheduler
# BLOOM_CAMPAIGN_ENABLED=1
# BLOOM_CAMPAIGN_DATE=2026-03-26
# BLOOM_SEND_GROUP_WELCOME=1
# После отправки приветствия в группу поставь BLOOM_SEND_GROUP_WELCOME=0 чтобы не дублировать при рестарте

# Канон Блума: каталог, где лежит BLOOM_START_PROMPT.txt (по умолчанию — Bloom/ в репозитории)
# BLOOM_HOME=/home/you/bridge/Bloom

# --- Остров (islanddream.ru): расписание в личку ---
# Базовый URL API без хвостового слэша. На проде обычно корень домена (маршруты /schedule, /dreams/...),
# без префикса /api — если у nginx иначе, сверь один раз.
# ISLAND_API_BASE_URL=https://islanddream.ru
# Опционально: ключ для nginx X-Api-Key
# ISLAND_API_KEY=
# ISLAND_HTTP_TIMEOUT_SEC=30
# Включить крон утро/вечер и ручные /link, /report
# ISLAND_SCHEDULE_ENABLED=1
# Часовой пояс для «сегодня» и времени крона
# ISLAND_TIMEZONE=Europe/Moscow
# ISLAND_MORNING_HOUR=7
# ISLAND_MORNING_MINUTE=0
# ISLAND_EVENING_HOUR=22
# ISLAND_EVENING_MINUTE=0
# Пока нет POST привязки на backend: tg_id:user_id через запятую
# ISLAND_TELEGRAM_USER_MAP=310055372:1
# Когда Форж добавит endpoint: полный URL или base + путь
# ISLAND_LINK_CONFIRM_URL=https://islanddream.ru/telegram/link/confirm
# ISLAND_LINK_CONFIRM_PATH=telegram/link/confirm
# Минуты для POST лога книги за день
# ISLAND_BOOK_LOG_MINUTES=15
