# Скопируй в .env и подставь свои значения (файл .env в репозиторий не коммитится).

# Telegram
# TELEGRAM_BOT_TOKEN=
# ADMIN_TELEGRAM_ID=
# MARATHON_GROUP_IDS=

# --- AI: «Живой Мост» — сначала Gemini, при 429/503 после ретраев — Groq (OpenAI-compatible) ---
# Ключ Google AI (Gemini). Можно задать как PRIMARY_API_KEY или как раньше:
# PRIMARY_API_KEY=
# GOOGLE_AI_KEY=
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_FALLBACK=
# GEMINI_API_VERSION=v1beta

# Запасной канал (Groq): ключ и опционально URL/модель
# FALLBACK_API_KEY=
# То же, что FALLBACK_API_KEY (если удобнее старое имя):
# GROQ_API_KEY=
# FALLBACK_BASE_URL=https://api.groq.com/openai/v1
# FALLBACK_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=

# PostgreSQL (опционально; пароль с # & лучше в кавычках)
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_USER=
# POSTGRES_PASSWORD=""
# POSTGRES_DB=
# Либо одной строкой для библиотек, ожидающих URL (спецсимволы в пароле — URL-encode)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Дайджест мечт из БД (после старта бота, один раз; для теста 60 с, в бою обычно 0)
# Нужны POSTGRES_* выше и: pip install 'psycopg[binary]'
# DREAM_DIGEST_BOOT_DELAY_SEC=60
# DREAM_DIGEST_BOOT_DELAY_SEC=0
